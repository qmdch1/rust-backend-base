# ===========================================
# Rust Backend Base - Environment Configuration
# ===========================================
# .env.example → .env 로 복사 후 값을 설정하세요.
# 이 파일의 모든 항목이 K8s Secret으로 주입됩니다.

# Server
RUST_ENV=production               # development | staging | production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@postgres-service:5432/rust_backend
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# Redis / Valkey
REDIS_URL=redis://valkey-service:6379

# JWT
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING
JWT_ACCESS_TOKEN_EXPIRY_SECS=3600       # 1 hour
JWT_REFRESH_TOKEN_EXPIRY_SECS=604800    # 7 days

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Logging
RUST_LOG=rust_backend_base=info,tower_http=info
