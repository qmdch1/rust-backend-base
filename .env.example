# ===========================================
# Rust Backend Base - Environment Configuration
# ===========================================

# Server
RUST_ENV=development          # development | staging | production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rust_backend
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ACCESS_TOKEN_EXPIRY_SECS=3600       # 1 hour
JWT_REFRESH_TOKEN_EXPIRY_SECS=604800    # 7 days

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
RUST_LOG=rust_backend_base=debug,tower_http=debug
